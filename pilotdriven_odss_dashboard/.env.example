ODSS_ENV=development

# Bounded ODSS work state. PilotDriven remains the durable commercial store.
ODSS_DATA_DIR=/var/lib/pilotdriven-odss

# Service-to-service authentication used by PilotDriven and the Playwright worker.
ODSS_SERVICE_TOKEN=replace-with-a-long-random-token

# Optional legacy single-user dashboard Basic Auth.
ODSS_USERNAME=
ODSS_PASSWORD=

# Product policy windows. Destination/alternate defaults to ETA +/- 2 hours.
ODSS_NOTAM_DEPARTURE_WINDOW_MINUTES=60
ODSS_NOTAM_ARRIVAL_WINDOW_MINUTES=120

# Official public NOAA/AWC international SIGMET source. Positive volcanic-ash
# intersections are authoritative; incomplete future coverage fails closed to
# review-required rather than being presented as "no volcanic ash".
ODSS_VA_SIGMET_SOURCE=awc
ODSS_VA_SIGMET_URL=https://aviationweather.gov/api/data/isigmet?format=json
ODSS_VA_SIGMET_TIMEOUT_SECONDS=8
ODSS_VA_SIGMET_FRESHNESS_MINUTES=15
ODSS_VA_SIGMET_CACHE_SECONDS=60
ODSS_VA_SIGMET_USER_AGENT=PilotDriven-ODSS/0.6.1 (operational-briefing service)

# ODSS v0.6 realistic map configuration.
ODSS_MAP_PROVIDER=aws-location
AWS_REGION=ap-southeast-1
AWS_LOCATION_API_KEY=
ODSS_MAP_STYLE=Hybrid
ODSS_MAP_LANGUAGE=en
ODSS_MAP_FALLBACK=static
ODSS_MAP_SCREENSHOT_TIMEOUT_SECONDS=30
ODSS_MAP_PRINT_BASE_URL=http://127.0.0.1:8000
